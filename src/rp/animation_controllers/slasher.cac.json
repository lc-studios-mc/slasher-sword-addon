{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.slasher.slasher.fp": {
			"initial_state": "pick",
			"states": {
				"pick": {
					"animations": ["anim.fp.pick"],
					"transitions": [
						{ "general": "q.all_animations_finished" },
						{ "speed_slash_1": "v.cd_speed_slash_1" },
						{ "speed_slash_2": "v.cd_speed_slash_2" },
						{ "charge_1": "v.cd_charge" }
					]
				},

				"general": {
					"animations": ["anim.fp.general"],
					"transitions": [
						{ "pick": "v.cd_pick" },
						{ "speed_slash_1": "v.cd_speed_slash_1" },
						{ "speed_slash_2": "v.cd_speed_slash_2" },
						{ "charge_1": "v.cd_charge" }
					],
					"blend_transition": 0.08
				},

				"speed_slash_1": {
					"animations": ["anim.fp.speed_slash_1"],
					"transitions": [
						{ "pick": "!v.cd_speed_slash_1 || v.cd_pick" },
						{ "speed_slash_2": "v.cd_speed_slash_2" },
						{ "charge_2": "v.cd_charge" }
					]
				},

				"speed_slash_2": {
					"animations": ["anim.fp.speed_slash_2"],
					"transitions": [
						{ "pick": "!v.cd_speed_slash_2 || v.cd_pick" },
						{ "speed_slash_1": "v.cd_speed_slash_1" },
						{ "charge_2": "v.cd_charge" }
					]
				},

				"charge_1": {
					"animations": ["anim.fp.charge_1"],
					"transitions": [
						{ "pick": "v.cd_charge_cancel || v.cd_pick" },
						{ "power_slash": "v.cd_power_slash" }
					]
				},

				"charge_2": {
					"animations": ["anim.fp.charge_2"],
					"transitions": [
						{ "pick": "v.cd_charge_cancel || v.cd_pick" },
						{ "power_slash": "v.cd_power_slash" }
					]
				},

				"power_slash": {
					"animations": ["anim.fp.power_slash"],
					"transitions": [{ "pick": "v.cd_pick" }, { "charge_2": "v.cd_charge" }],
					"blend_transition": 0.08
				}
			}
		}
	}
}
